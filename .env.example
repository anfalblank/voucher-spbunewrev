# Database (SQLite)
# Database file will be created at ./lib/db/spbu-voucher.db

# Better Auth
BETTER_AUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"

# WhatsApp (Whabot API)
WHABOT_API_URL="https://api.whabot.com"
WHABOT_API_KEY="your-whabot-api-key"

# App
APP_NAME="SPBU Voucher Management"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Security
BCRYPT_ROUNDS=12

# Node Environment
NODE_ENV="development"
